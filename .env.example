# E2open API credentials and configuration.
# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# --- Credentials (you already have these) ---
USERNAME=Circle_API
PASSWORD=your-password-here
API_KEY=your-api-key-here

# --- Tenant / connection settings (override as needed) ---
# Your TMS host. Common patterns:
#   https://na-api.tms.e2open.com        (North America)
#   https://eu-api.tms.e2open.com        (Europe)
#   https://<region>-api.tms.blujaysolutions.net
E2OPEN_BASE_URL=https://na-api.tms.e2open.com

# Auth mode to try first: "api_key" (Basic base64(USERNAME:API_KEY)),
# "session" (LeanSessionID from USERNAME/PASSWORD), or "auto" (try both).
E2OPEN_AUTH_MODE=auto

# Optional: where the session-auth endpoint lives (relative to base URL).
E2OPEN_AUTH_PATH=/Integration/xml/authenticate
